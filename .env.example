# Supabase
# Supabaseプロジェクトの設定 > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠️ service_role キーは絶対にクライアントコードで使用禁止
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Hotpepper API（サーバーサイド専用 - クライアントに露出禁止）
# https://webservice.recruit.co.jp/ でAPIキーを取得
HOTPEPPER_API_KEY=your_hotpepper_api_key_here

# アプリURL（招待リンク生成に使用）
# ローカル開発: http://localhost:3000 / 本番: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
