# ============================================================
# 環境変数・シークレット
# ============================================================
# 実際のAPIキーや接続情報が含まれるため絶対にコミット禁止
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example は値が入っていないテンプレートなので追跡対象

# ============================================================
# Next.js ビルド成果物
# ============================================================
# next build で自動生成されるキャッシュ・バンドルファイル群
.next/
# next export の出力先
out/

# ============================================================
# Node.js 依存パッケージ
# ============================================================
# npm install / yarn install で都度再生成できるため不要
node_modules/

# ============================================================
# Vercel デプロイ設定
# ============================================================
# Vercel CLI が生成するプロジェクトリンク情報（ローカル固有）
.vercel

# ============================================================
# macOS システムファイル
# ============================================================
# Finder が自動生成するメタデータファイル
.DS_Store

# ============================================================
# ログファイル
# ============================================================
# npm/yarn の実行ログ（エラー調査後は不要）
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# TypeScript ビルドキャッシュ
# ============================================================
# tsc が生成するインクリメンタルビルドキャッシュ
*.tsbuildinfo
next-env.d.ts
